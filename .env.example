# ============================================================
# Local Environment Template for Spec Kit n8n Orchestrator
# ============================================================
# Kopiere diese Datei nach .env.local und trage deinen
# n8n API-Key ein.
#
# Wichtig:
# - .env.local wird von Git ignoriert (siehe .gitignore).
# - .env.example enthält NUR Platzhalter, niemals echte Keys.
# - API-Key niemals in Chat, Git, Evidence oder Logs kopieren.
# - Bei versehentlichem Leak: Key sofort in n8n rotieren.
# ============================================================

# n8n Basis-URL (lokal oder remote)
N8N_BASE_URL=http://192.168.1.52:5678

# Dein n8N API-Key (User-spezifisch, kein Admin-Key nötig)
# Ersetze den Platzhalter durch deinen echten Key.
N8N_API_KEY=PASTE_YOUR_N8N_API_KEY_HERE

# Erwarteter Workflow-Name in n8n
SPEC_KIT_EXPECTED_WORKFLOW_NAME=Spec Kit OpenCode Proxmox Runner Orchestrator

# Erwarteter Webhook-Pfad (ohne führenden Slash)
SPEC_KIT_EXPECTED_WEBHOOK_PATH=spec-kit-opencode-proxmox-runner

# Erwarteter Credential-Name in n8n
SPEC_KIT_EXPECTED_CREDENTIAL_NAME=Proxmox Docker Host SSH

# Nur Credential-Metadaten prüfen, keine Live-Tests
SPEC_KIT_ACCEPT_CREDENTIAL_METADATA_ONLY=true

# ============================================================
# OpenCode Runner Provider Configuration (Template)
# ============================================================
# These values are used in the Runner LXC under
#   /opt/dev-fabric/secrets/opencode-provider.env
# and loaded by /opt/dev-fabric/bin/load-opencode-provider-env.sh
#
# IMPORTANT: Two different provider types exist:
#
#   opencode-go  → OpenCode Platform (needs OpenCode Platform key)
#                  Get key from: https://opencode.ai/auth
#                  DO NOT use with direct DeepSeek API keys!
#
#   deepseek     → Direct DeepSeek API (needs DeepSeek API key)
#                  Get key from: https://platform.deepseek.com/api_keys
#                  DO NOT use with OpenCode Platform keys!
#
# NEVER mix keys between provider types.
# NEVER put real keys in this template file.
# ============================================================

# AI Provider Name
#   deepseek       = built-in DeepSeek provider (uses DEEPSEEK_API_KEY)
#   opencode-go    = OpenCode Platform provider (uses OPENCODE_API_KEY)
OPENCODE_PROVIDER=PASTE_PROVIDER_NAME_HERE

# API Key for the selected provider
#   For deepseek: your DeepSeek API key from platform.deepseek.com
#   For opencode-go: your OpenCode Platform key from opencode.ai/auth
OPENCODE_API_KEY=PASTE_PROVIDER_API_KEY_HERE

# Model Identifier
#   For deepseek: deepseek-v4-pro (thinking) or deepseek-v4-flash (fast)
#   For opencode-go: check available models with `opencode models opencode`
OPENCODE_MODEL=PASTE_MODEL_NAME_HERE

# DeepSeek Base URL (validated: https://api.deepseek.com/v1)
# Only needed for custom provider fallback; built-in provider has it implicit
OPENCODE_BASE_URL=https://api.deepseek.com/v1

# Cost Limit per Run (USD)
OPENCODE_MAX_COST_USD=0.25

# Dry-Run Mode (true = no agent runs without explicit approval)
OPENCODE_DRY_RUN=true

# Provider Call Gate (true = smoke test may execute real API calls)
# Only set to true when API key is configured AND testing is desired
OPENCODE_ALLOW_PROVIDER_CALL=false
